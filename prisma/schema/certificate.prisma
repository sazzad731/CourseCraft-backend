model Certificate {
  id        String   @id @default(uuid())
  score     Float
  issued_at DateTime @default(now())

  // Foreign Keys
  user_id   String
  course_id String

  // Relationships
  user      User     @relation(fields: [user_id], references: [id])
  course    Course   @relation(fields: [course_id], references: [id])

  @@index([user_id])
  @@index([course_id])
  @@unique([user_id, course_id]) // Usually, one certificate per course per user
}